# ============================================================
# JRC Voice Quality Analytics — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no repositório
# ============================================================

# ----------------------------------------------------------
# SUPABASE — obrigatório para salvar e consultar análises
# ----------------------------------------------------------
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ----------------------------------------------------------
# OPENAI — opcional
#
# OPENAI_API_KEY:
#   Necessária apenas para usar o botão "Processar com OpenAI"
#   (transcrição + análise via GPT). Sem ela, o sistema usa
#   o Whisper local no navegador + motor de regras offline.
#   Deixe vazio para rodar 100% no modo local gratuito.
#
# OPENAI_BASE_URL:
#   Opcional. Use SOMENTE se você tiver um gateway ou proxy
#   compatível com a API da OpenAI (ex: Azure OpenAI, LiteLLM,
#   OpenRouter, etc.). Se estiver usando a API oficial da
#   OpenAI, deixe este campo VAZIO.
# ----------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Modelos utilizados quando OPENAI_API_KEY estiver preenchida
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini

# ----------------------------------------------------------
# SERVIDOR
# ----------------------------------------------------------
PORT=3000
